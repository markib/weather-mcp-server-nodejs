# Weather MCP Server Environment Configuration
# Copy this file to .env and customize the values for your environment

# Server Configuration
SERVER_NAME=weather-mcp-server
SERVER_VERSION=1.0.0

# Authentication Settings
AUTH_ENABLED=true
BEARER_TOKEN=your-secret-bearer-token-here

# Supported Cities (comma-separated)
SUPPORTED_CITIES=New York,London,Tokyo,Saigon

# Weather API Limits
MAX_FORECAST_DAYS=7
MAX_LOCATION_LENGTH=100

# Rate Limiting
RATE_LIMIT_WINDOW_MS=1000
MAX_REQUESTS_PER_WINDOW=100

# MCP Client Authentication Token
# This token is used when clients connect to the server
MCP_AUTH_TOKEN=your-secret-bearer-token-here